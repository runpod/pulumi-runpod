{
  "name": "runpod",
  "displayName": "RunPod",
  "description": "Manage RunPod GPU cloud resources.",
  "keywords": [
    "category/infrastructure",
    "kind/native"
  ],
  "homepage": "https://www.runpod.io",
  "license": "Apache-2.0",
  "repository": "https://github.com/runpod/pulumi-runpod",
  "pluginDownloadURL": "github://api.github.com/runpod/pulumi-runpod",
  "publisher": "RunPod",
  "namespace": "runpod",
  "meta": {
    "moduleFormat": "(.*)"
  },
  "language": {
    "csharp": {
      "respectSchemaVersion": true,
      "rootNamespace": "Pulumi"
    },
    "go": {
      "generateResourceContainerTypes": true,
      "importBasePath": "github.com/runpod/pulumi-runpod/sdk/go/runpod",
      "respectSchemaVersion": true
    },
    "nodejs": {
      "packageName": "pulumi-runpod",
      "respectSchemaVersion": true
    },
    "python": {
      "packageName": "pulumi_runpod",
      "pyproject": {
        "enabled": true
      },
      "respectSchemaVersion": true
    }
  },
  "config": {
    "variables": {
      "apiKey": {
        "type": "string",
        "description": "The RunPod API key for authentication. Can also be set via the RUNPOD_API_KEY environment variable.",
        "defaultInfo": {
          "environment": [
            "RUNPOD_API_KEY"
          ]
        },
        "secret": true
      },
      "apiUrl": {
        "type": "string",
        "description": "The RunPod API URL. Defaults to https://api.runpod.io/graphql. Can also be set via the RUNPOD_API_URL environment variable.",
        "defaultInfo": {
          "environment": [
            "RUNPOD_API_URL"
          ]
        }
      }
    }
  },
  "types": {
    "runpod:index:CPUFlavorOutput": {
      "properties": {
        "diskLimitPerVcpu": {
          "type": "integer",
          "description": "Disk limit per vCPU (in GB)."
        },
        "displayName": {
          "type": "string",
          "description": "The human-readable name of the CPU flavor."
        },
        "groupId": {
          "type": "string",
          "description": "The group this flavor belongs to."
        },
        "groupName": {
          "type": "string",
          "description": "The display name of the flavor group."
        },
        "id": {
          "type": "string",
          "description": "The unique identifier of the CPU flavor (used as flavorId in instanceId)."
        },
        "maxVcpu": {
          "type": "integer",
          "description": "The maximum number of vCPUs for this flavor."
        },
        "minVcpu": {
          "type": "number",
          "description": "The minimum number of vCPUs for this flavor."
        },
        "ramMultiplier": {
          "type": "number",
          "description": "RAM allocated per vCPU (in GB)."
        },
        "vcpuBurstable": {
          "type": "boolean",
          "description": "Whether vCPUs are burstable."
        }
      },
      "type": "object",
      "required": [
        "diskLimitPerVcpu",
        "displayName",
        "groupId",
        "groupName",
        "id",
        "maxVcpu",
        "minVcpu",
        "ramMultiplier",
        "vcpuBurstable"
      ]
    },
    "runpod:index:DataCenterOutput": {
      "properties": {
        "compliance": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Compliance certifications held by this data center."
        },
        "globalNetwork": {
          "type": "boolean",
          "description": "Whether this data center is part of the global network."
        },
        "gpuAvailability": {
          "type": "array",
          "items": {
            "$ref": "#/types/runpod:index:GpuAvailabilityItem"
          },
          "description": "GPU availability within this data center."
        },
        "id": {
          "type": "string",
          "description": "The unique identifier of the data center (used as dataCenterId)."
        },
        "listed": {
          "type": "boolean",
          "description": "Whether this data center is publicly listed."
        },
        "location": {
          "type": "string",
          "description": "The geographic location of the data center."
        },
        "name": {
          "type": "string",
          "description": "The display name of the data center."
        },
        "region": {
          "type": "string",
          "description": "The broad region (e.g. NORTH_AMERICA, EUROPE)."
        },
        "storageSupport": {
          "type": "boolean",
          "description": "Whether this data center supports network volumes."
        }
      },
      "type": "object",
      "required": [
        "compliance",
        "globalNetwork",
        "gpuAvailability",
        "id",
        "listed",
        "location",
        "name",
        "region",
        "storageSupport"
      ]
    },
    "runpod:index:EndpointNetworkVolumeBinding": {
      "properties": {
        "dataCenterId": {
          "type": "string"
        },
        "networkVolumeId": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "dataCenterId",
        "networkVolumeId"
      ]
    },
    "runpod:index:GpuAvailabilityItem": {
      "properties": {
        "available": {
          "type": "boolean",
          "description": "Whether this GPU type is currently available at this data center."
        },
        "gpuTypeDisplayName": {
          "type": "string",
          "description": "The human-readable GPU type name."
        },
        "gpuTypeId": {
          "type": "string",
          "description": "The GPU type identifier."
        },
        "stockStatus": {
          "type": "string",
          "description": "Current stock status (e.g. High, Medium, Low)."
        }
      },
      "type": "object",
      "required": [
        "available",
        "gpuTypeDisplayName",
        "gpuTypeId",
        "stockStatus"
      ]
    },
    "runpod:index:GpuTypeOutput": {
      "properties": {
        "communityCloud": {
          "type": "boolean",
          "description": "Whether the GPU is available in community cloud."
        },
        "communityPrice": {
          "type": "number",
          "description": "The price per hour in community cloud (USD)."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the GPU type."
        },
        "id": {
          "type": "string",
          "description": "The unique identifier of the GPU type."
        },
        "lowestPrice": {
          "$ref": "#/types/runpod:index:LowestPriceOutput"
        },
        "maxGpuCount": {
          "type": "integer",
          "description": "The maximum number of this GPU type that can be allocated."
        },
        "memoryInGb": {
          "type": "integer",
          "description": "The amount of VRAM in GB."
        },
        "secureCloud": {
          "type": "boolean",
          "description": "Whether the GPU is available in secure cloud."
        },
        "securePrice": {
          "type": "number",
          "description": "The price per hour in secure cloud (USD)."
        }
      },
      "type": "object",
      "required": [
        "communityCloud",
        "communityPrice",
        "displayName",
        "id",
        "maxGpuCount",
        "memoryInGb",
        "secureCloud",
        "securePrice"
      ]
    },
    "runpod:index:LowestPriceOutput": {
      "properties": {
        "minimumBidPrice": {
          "type": "number"
        },
        "rentedCount": {
          "type": "integer"
        },
        "stockStatus": {
          "type": "string"
        },
        "totalCount": {
          "type": "integer"
        },
        "uninterruptablePrice": {
          "type": "number"
        }
      },
      "type": "object",
      "required": [
        "minimumBidPrice",
        "rentedCount",
        "stockStatus",
        "totalCount",
        "uninterruptablePrice"
      ]
    },
    "runpod:index:SavingsPlan": {
      "properties": {
        "planLength": {
          "type": "string",
          "description": "The length of the savings plan."
        },
        "upfrontCost": {
          "type": "number",
          "description": "The upfront cost for the savings plan."
        }
      },
      "type": "object"
    },
    "runpod:index:TemplatePortConfig": {
      "properties": {
        "name": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "port"
      ]
    }
  },
  "provider": {
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "The RunPod API key for authentication. Can also be set via the RUNPOD_API_KEY environment variable.",
        "defaultInfo": {
          "environment": [
            "RUNPOD_API_KEY"
          ]
        },
        "secret": true
      },
      "apiUrl": {
        "type": "string",
        "description": "The RunPod API URL. Defaults to https://api.runpod.io/graphql. Can also be set via the RUNPOD_API_URL environment variable.",
        "defaultInfo": {
          "environment": [
            "RUNPOD_API_URL"
          ]
        }
      }
    },
    "type": "object",
    "inputProperties": {
      "apiKey": {
        "type": "string",
        "description": "The RunPod API key for authentication. Can also be set via the RUNPOD_API_KEY environment variable.",
        "defaultInfo": {
          "environment": [
            "RUNPOD_API_KEY"
          ]
        },
        "secret": true
      },
      "apiUrl": {
        "type": "string",
